.:53 {
    # Log every single DNS query with timestamp and client IP
    log . {
        class all
    }

    # Forward to real DNS so apps actually work
    forward . 1.1.1.1 8.8.8.8 {
        policy sequential
    }

    # Cache responses (short TTL so we still see repeated queries)
    cache 30

    # Enable error logging
    errors
}
